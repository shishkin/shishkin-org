{
  "name": "shishkin.org",
  "version": "1.0.0",
  "description": "Personal site",
  "type": "module",
  "scripts": {
    "start": "node --watch server.ts",
    "generate": "node node_modules/@mastrojs/mastro/src/generator.js --output dist",
    "build": "tsc --noEmit && pnpm run generate"
  },
  "imports": {
    "#*": "./*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shishkin/shishkin-org.git"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "keywords": [],
  "author": "Sergey Shishkin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shishkin/shishkin-org/issues"
  },
  "homepage": "https://github.com/shishkin/shishkin-org#readme",
  "dependencies": {
    "@iconify-json/carbon": "1.2.22",
    "@iconify-json/fa": "1.2.2",
    "@iconify-json/ion": "1.2.7",
    "@mastrojs/mastro": "jsr:0.8.6",
    "@remix-run/node-fetch-server": "0.11.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/node": "^24",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
