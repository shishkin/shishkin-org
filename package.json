{
  "name": "shishkin.org",
  "version": "1.0.0",
  "description": "Personal site",
  "type": "module",
  "scripts": {
    "start": "node --watch server.ts",
    "generate": "node node_modules/@mastrojs/mastro/src/generator.js --output dist",
    "build": "tsc --noEmit && pnpm run generate"
  },
  "imports": {
    "#*": "./*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shishkin/shishkin-org.git"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "keywords": [],
  "author": "Sergey Shishkin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shishkin/shishkin-org/issues"
  },
  "homepage": "https://github.com/shishkin/shishkin-org#readme",
  "dependencies": {
    "@iconify-json/carbon": "1.2.24",
    "@iconify-json/fa": "1.2.2",
    "@iconify-json/ion": "1.2.7",
    "@mastrojs/mastro": "jsr:0.8.6",
    "@remix-run/node-fetch-server": "0.14.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.2",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
