{
  "name": "shishkin.org",
  "version": "1.0.0",
  "description": "Personal site",
  "type": "module",
  "scripts": {
    "start": "node --watch server.ts",
    "generate": "node node_modules/@mastrojs/mastro/src/generator.js --output dist",
    "build": "tsc --noEmit && pnpm run generate"
  },
  "imports": {
    "#*": "./*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shishkin/shishkin-org.git"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "keywords": [],
  "author": "Sergey Shishkin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shishkin/shishkin-org/issues"
  },
  "homepage": "https://github.com/shishkin/shishkin-org#readme",
  "dependencies": {
    "@iconify-json/carbon": "1.2.23",
    "@iconify-json/fa": "1.2.2",
    "@iconify-json/ion": "1.2.7",
    "@mastrojs/mastro": "jsr:0.8.6",
    "@remix-run/node-fetch-server": "0.13.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.1",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
